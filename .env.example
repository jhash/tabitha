# Copy to .env for local development.

# Local Postgres 17 via homebrew: `brew services start postgresql@17`
DATABASE_URL=postgres://localhost:5432/tabitha_dev?sslmode=disable

APP_URL=http://localhost:8080
PORT=8080

# Session cookie signing / server-side session lookups.
SESSION_SECRET=change-me-to-a-long-random-string

# AES-256 key for encrypting stored Google OAuth tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Google Cloud Console OAuth client (goth). Callback: {APP_URL}/auth/google/callback
GOOGLE_KEY=
GOOGLE_SECRET=

# Optional: ntfy.sh topic URL for re-auth push notifications when the
# stored Google OAuth token goes stale. Leave blank to disable.
NTFY_URL=

# Optional: Cloudflare cache auto-purge when a song/status changes (see
# docs/cloudflare.md). Both must be set for it to do anything — leave
# blank to disable (a stale cached page just needs a manual purge instead).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
